# Database — Vercel Postgres (Neon)
POSTGRES_URL=

# Auth.js (next-auth v5)
# AUTH_SECRET is the v5 name; NEXTAUTH_SECRET is still read for compatibility.
AUTH_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Email (Resend) — magic-link sign-in for GM and above
RESEND_API_KEY=
# Verified sender address for magic-link emails (e.g. "Mikana <floor@yourdomain.com>")
AUTH_RESEND_FROM=

# AI
OPENAI_API_KEY=

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Same value as VAPID_PUBLIC_KEY, exposed to the browser for subscription
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# Contact used in the VAPID JWT (mailto: or https:)
VAPID_SUBJECT=mailto:ops@mikana.example
